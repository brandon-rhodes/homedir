#!/usr/bin/env python3

import datetime as dt

def till(target):
    today = dt.date.today()
    days = (target - today).days
    weeks = days / 7.0
    print('{} days = {:.1f} weeks'.format(days, weeks))

target = dt.date(2026, 3, 15)
print(f'Weeks until {target.strftime("%Y %B %d")}:')
till(target)
