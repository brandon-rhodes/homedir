#!/bin/bash
#
# Run 'uncommitted' on my home directory, saving its output in a file.

cd

out=UNCOMMITTED
number=0
while [ -e "$out" ]; do
    printf -v out 'UNCOMMITTED.%d' "$(( ++number ))"
done

if [ -n "$1" ]
then
    exec uvx uncommitted "$@"
fi

uvx uncommitted -s -v . > $out

less $out
echo $out
